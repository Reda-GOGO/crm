{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "outDir": "dist-server",
    "rootDir": "."
  },
  "include": [
    "server.ts",
    "routers/**/*",
    "services/**/*",
    "prisma/**/*",
    "uploads/**/*"
  ]
}
