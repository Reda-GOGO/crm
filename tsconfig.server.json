{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true
  },
  "include": [
    "server.ts",
    "routers/**/*",
    "middlewares/**/*",
    "generated/**/*",
    "prisma/**/*",
    "utilities/**/*",
    "services/**/*"
  ]
}
