{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist-server",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true
  },
  "include": [
    "server.ts",
    "models/**/*",
    "routers/**/*",
    "services/**/*"
  ]
}
